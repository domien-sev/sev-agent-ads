# Agent config
AGENT_NAME=ads
AGENT_PORT=3000
AGENT_ENDPOINT=http://localhost:3000

# Central Directus
SEV_AI_DIRECTUS_URL=https://directus.sev.ai
SEV_AI_DIRECTUS_TOKEN=

# Shopify (product sync)
SHOPIFY_SHOP=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# LLM (brief generation)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Creative generation
CREATOMATE_API_KEY=
FLUX_API_KEY=
FLUX_BACKEND=openrouter          # "bfl" for direct BFL API, "openrouter" for OpenRouter proxy
FLUX_MODEL=black-forest-labs/flux.2-pro    # OpenRouter model ID (only used with openrouter backend)
OPENAI_IMAGE_API_KEY=              # OpenRouter key (same as FLUX_API_KEY) or direct OpenAI key
OPENAI_IMAGE_BACKEND=openrouter    # "openai" for direct, "openrouter" for OpenRouter proxy
OPENAI_IMAGE_MODEL=openai/gpt-5-image  # OpenRouter model ID
PHOTOROOM_API_KEY=

# Video generation
CREATIFY_API_ID=
CREATIFY_API_KEY=
FAL_KEY=
PLAINLY_API_KEY=

# S3-compatible asset storage (Hetzner Object Storage, Cloudflare R2, AWS S3)
S3_ENDPOINT=https://your-region.your-s3-provider.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=sev-ads-creatives
S3_PUBLIC_URL=
S3_REGION=auto
S3_FORCE_PATH_STYLE=true

# Meta Marketing API
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# TikTok Marketing API
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Pinterest Ads API
PINTEREST_ACCESS_TOKEN=
PINTEREST_AD_ACCOUNT_ID=

# Slack (optional, used for direct notifications)
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
